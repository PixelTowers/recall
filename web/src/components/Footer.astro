---
// ABOUTME: Footer with links, credits, and Lucide heart icon.
// ABOUTME: Clean layout with product, company, and legal sections.
---

<footer class="px-6 py-12 bg-gray-950 text-gray-100 border-t border-gray-800">
  <div class="mx-auto max-w-6xl">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-12 mb-8">
      <!-- Brand -->
      <div>
        <h3 class="font-semibold mb-4 text-lg text-gray-50">Recall</h3>
        <p class="text-gray-400 text-sm">
          Never lose your form data again. Save, restore, and export with one click.
        </p>
      </div>

      <!-- Product -->
      <div>
        <h4 class="font-semibold mb-4 text-gray-50">Product</h4>
        <ul class="space-y-2 text-sm">
          <li><a href="#features" class="text-gray-400 hover:text-gray-100 transition-colors">Features</a></li>
          <li><a href="#privacy" class="text-gray-400 hover:text-gray-100 transition-colors">Privacy</a></li>
          <li><a href="https://github.com/PixelTowers/recall" target="_blank" rel="noopener noreferrer" class="text-gray-400 hover:text-gray-100 transition-colors">GitHub</a></li>
        </ul>
      </div>

      <!-- Company -->
      <div>
        <h4 class="font-semibold mb-4 text-gray-50">Company</h4>
        <ul class="space-y-2 text-sm">
          <li><a href="https://pixeltowers.io" target="_blank" rel="noopener noreferrer" class="text-gray-400 hover:text-gray-100 transition-colors">PixelTowers</a></li>
          <li><a href="/privacy" class="text-gray-400 hover:text-gray-100 transition-colors">Privacy Policy</a></li>
        </ul>
      </div>

      <!-- Legal -->
      <div>
        <h4 class="font-semibold mb-4 text-gray-50">Legal</h4>
        <ul class="space-y-2 text-sm">
          <li><a href="https://github.com/PixelTowers/recall/blob/main/LICENSE" target="_blank" rel="noopener noreferrer" class="text-gray-400 hover:text-gray-100 transition-colors">MIT License</a></li>
        </ul>
      </div>
    </div>

    <!-- Divider -->
    <div class="border-t border-gray-800 pt-8">
      <div class="flex flex-col md:flex-row items-center justify-between gap-4 text-sm text-gray-400">
        <p>&copy; {new Date().getFullYear()} Recall. All rights reserved.</p>
        <p class="flex items-center gap-1">
          Made with <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" stroke="none" class="text-red-500"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg> by <a href="https://pixeltowers.io" target="_blank" rel="noopener noreferrer" class="text-gray-300 hover:text-gray-100 underline transition-colors">PixelTowers</a>
        </p>
      </div>
    </div>
  </div>
</footer>
