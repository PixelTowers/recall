---
// ABOUTME: Features section with 5 feature cards.
// ABOUTME: Save, Restore, Export, Auto-save, and Open Source.
---

<section id="features" class="px-6 py-20 bg-gray-100 dark:bg-gray-950">
  <div class="mx-auto max-w-6xl">
    <h2 class="text-4xl md:text-5xl font-bold text-center text-gray-900 dark:text-white mb-4">Powerful features, simple interface</h2>
    <p class="text-center text-lg text-gray-600 dark:text-gray-400 mb-16 max-w-2xl mx-auto">
      Everything you need to never lose form data again, built with privacy and simplicity in mind.
    </p>

    <!-- Screenshots -->
    <div class="flex flex-col md:flex-row items-center justify-center gap-8 mb-16">
      <img src="/screenshots/popup-empty.jpg" alt="Recall popup — empty state" class="rounded-xl shadow-lg border border-gray-200 dark:border-gray-800 w-56" />
      <img src="/screenshots/popup-snapshots.jpg" alt="Recall popup — saved snapshots" class="rounded-xl shadow-lg border border-gray-200 dark:border-gray-800 w-56" />
      <img src="/screenshots/settings.jpg" alt="Recall settings — auto-save configuration" class="rounded-xl shadow-lg border border-gray-200 dark:border-gray-800 w-80" />
    </div>

    <!-- Features Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      <!-- Save -->
      <div class="rounded-lg border border-gray-200 dark:border-gray-800 bg-gray-200 dark:bg-gray-900 p-8 hover:border-blue-600 dark:hover:border-blue-400 transition-colors">
        <div class="text-4xl mb-4">💾</div>
        <h3 class="text-xl font-semibold text-gray-900 dark:text-white mb-3">One-Click Save</h3>
        <p class="text-gray-600 dark:text-gray-400">
          Capture all form fields on any page in a single click. Recall automatically detects and saves your data instantly.
        </p>
      </div>

      <!-- Restore -->
      <div class="rounded-lg border border-gray-200 dark:border-gray-800 bg-gray-200 dark:bg-gray-900 p-8 hover:border-blue-600 dark:hover:border-blue-400 transition-colors">
        <div class="text-4xl mb-4">↩️</div>
        <h3 class="text-xl font-semibold text-gray-900 dark:text-white mb-3">Instant Restore</h3>
        <p class="text-gray-600 dark:text-gray-400">
          Refill any form with a saved snapshot. Perfect for recovering from crashes or accidentally navigating away.
        </p>
      </div>

      <!-- Export -->
      <div class="rounded-lg border border-gray-200 dark:border-gray-800 bg-gray-200 dark:bg-gray-900 p-8 hover:border-blue-600 dark:hover:border-blue-400 transition-colors">
        <div class="text-4xl mb-4">📄</div>
        <h3 class="text-xl font-semibold text-gray-900 dark:text-white mb-3">Export Data</h3>
        <p class="text-gray-600 dark:text-gray-400">
          Download your form responses as Markdown files. Share, archive, or import your data anywhere you need it.
        </p>
      </div>

      <!-- Auto-save -->
      <div class="rounded-lg border border-gray-200 dark:border-gray-800 bg-gray-200 dark:bg-gray-900 p-8 hover:border-blue-600 dark:hover:border-blue-400 transition-colors">
        <div class="text-4xl mb-4">⏱️</div>
        <h3 class="text-xl font-semibold text-gray-900 dark:text-white mb-3">Auto-Save</h3>
        <p class="text-gray-600 dark:text-gray-400">
          Set up automatic snapshots at your preferred interval (10-300 seconds). Fire and forget form protection.
        </p>
      </div>

      <!-- Open Source -->
      <div class="rounded-lg border border-gray-200 dark:border-gray-800 bg-gray-200 dark:bg-gray-900 p-8 hover:border-blue-600 dark:hover:border-blue-400 transition-colors">
        <div class="text-4xl mb-4">🔓</div>
        <h3 class="text-xl font-semibold text-gray-900 dark:text-white mb-3">100% Open Source</h3>
        <p class="text-gray-600 dark:text-gray-400">
          MIT-licensed. Read the code, fork it, contribute. No vendor lock-in, no hidden agendas, complete transparency.
        </p>
      </div>

      <!-- Privacy -->
      <div class="rounded-lg border border-gray-200 dark:border-gray-800 bg-gray-200 dark:bg-gray-900 p-8 hover:border-blue-600 dark:hover:border-blue-400 transition-colors">
        <div class="text-4xl mb-4">🔒</div>
        <h3 class="text-xl font-semibold text-gray-900 dark:text-white mb-3">100% Local Storage</h3>
        <p class="text-gray-600 dark:text-gray-400">
          All data stays on your device. No servers, no accounts, no tracking. Your privacy is guaranteed.
        </p>
      </div>
    </div>
  </div>
</section>
